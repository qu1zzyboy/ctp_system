# SimNow 仿真环境（交易时段）
CTP_MD_FRONT=tcp://182.254.243.31:30011
CTP_TRADE_FRONT=tcp://182.254.243.31:30001

# SimNow 7x24 环境（当前网络拒绝连接，必要时再切回）
# CTP_MD_FRONT=tcp://182.254.243.31:40011
# CTP_TRADE_FRONT=tcp://182.254.243.31:40001

CTP_BROKER_ID=9999
CTP_APP_ID=simnow_client_test
CTP_AUTH_CODE=0000000000000000

# Server 专用：共享 MD 会话登录（与 Client 交易账号无关）
CTP_SERVER_USER_ID=
CTP_SERVER_PASSWORD=

# 各 Client 交易账号（按 CTP_CLIENT_ID 动态读取）
CTP_CLIENT_USER_ID=
CTP_CLIENT_PASSWORD=

CTP_INSTRUMENTS=rb2610,cu2608
RUST_LOG=info,ctp_server=debug,ctp_common=debug
